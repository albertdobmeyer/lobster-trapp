{
  "$schema": "https://raw.githubusercontent.com/nicknisi/tauri-config-schema/main/schema.json",
  "productName": "Lobster-TrApp",
  "version": "0.1.0",
  "identifier": "dev.lobster-trapp.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Lobster-TrApp",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' asset: https://img.shields.io; connect-src ipc: http://ipc.localhost"
    }
  },
  "bundle": {
    "active": true,
    "category": "DeveloperTool",
    "shortDescription": "Security-first desktop GUI for the OpenClaw ecosystem",
    "copyright": "Copyright (c) 2026 gitgoodordietrying",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "shell": {
      "open": true
    },
    "store": {}
  }
}
